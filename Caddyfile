#
# Enables the admin API (Can only be accessed locally because of Docker's port mapping)
#
{
        admin 0.0.0.0:9999
}

#
# Proxies the jpv3-webrepl service running on this same machine (and handles TLS for us)
#
jpv3.lisforge.net {
	reverse_proxy http://webrepl:8888
}

#
# Proxies the audiobooks service running on this same machine (and handles TLS for us)
#
audiobooks.kevinclarke.info {
	reverse_proxy http://audiobooks:80
}

#
# Proxies the music service running on this same machine (and handles TLS for us)
#
music.kevinclarke.info {
        reverse_proxy http://music:4533
}

#
# Proxies the ebooks service running on this same machine (and handles TLS for us)
#
ebooks.kevinclarke.info {
        reverse_proxy http://ebooks:5000
}
